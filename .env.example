# Telegram Bot API Token obtained from @BotFather (Required)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ_ExampleToken

# Comma-separated list of allowed Telegram user IDs (Required)
# Use /id command or bot like @userinfobot to obtain your numeric User ID
ALLOWED_USER_IDS=123456789,987654321

# Optional comma-separated list of allowed Telegram chat IDs
# If empty, command restriction by chat ID is disabled
ALLOWED_CHAT_IDS=

# Default IPv4 broadcast address for local Wake-on-LAN packets
DEFAULT_BROADCAST=192.168.0.255

# Default UDP port for Wake-on-LAN (Standard ports: 9 or 7)
DEFAULT_WOL_PORT=9

# Number of times to transmit each Magic Packet for reliability
DEFAULT_WOL_REPEAT=3

# Delay in milliseconds between consecutive Magic Packet transmissions
DEFAULT_WOL_DELAY_MS=250

# Subprocess ping timeout in seconds for host status checks
PING_TIMEOUT_SECONDS=2

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Directory path for storing persistent device data and log files
DATA_DIR=./data

# Maximum number of commands allowed per user per window
RATE_LIMIT_COMMANDS=10

# Rate limit time window in seconds
RATE_LIMIT_WINDOW_SECONDS=60

# Telegram Bot API long polling timeout in seconds
TELEGRAM_POLL_TIMEOUT_SECONDS=30
